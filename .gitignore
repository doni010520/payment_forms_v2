# =====================================================================
# Portal de Pagamentos FESF-SUS - .gitignore
# =====================================================================

# ---- Dependências (vão ser instaladas via npm install no deploy) ----
node_modules/
backend/node_modules/

# ---- Banco de dados local (PGlite) ----
# Não versionar — cada ambiente tem seu próprio banco
.pgdata/
backend/.pgdata/
*.db
*.sqlite
*.sqlite3

# ---- Uploads de fornecedores (anexos físicos) ----
# São arquivos de usuário, nunca devem ir pro git
.uploads/
backend/.uploads/
uploads/

# ---- Variáveis de ambiente (segredos) ----
# Cada ambiente (dev/staging/prod) tem seu .env
.env
.env.local
.env.production
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example

# ---- Configuração MCP (contém access tokens) ----
# .mcp.json tem o SUPABASE_ACCESS_TOKEN inline — NUNCA versionar
.mcp.json
backend/.mcp.json

# ---- Render API Token ----
.render-token
backend/.render-token

# ---- Connection string do banco ----
.database-url
backend/.database-url

# ---- Supabase service_role key (backend operations) ----
.supabase-service-key
backend/.supabase-service-key

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Sistema operacional ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- Editores ----
.vscode/
.idea/
*.iml

# ---- Build / coverage ----
dist/
build/
coverage/
.nyc_output/

# ---- Documentos de teste fictícios (gerados localmente) ----
# Estes são apenas para ambiente de teste/demo
nfe-teste-hecc.pdf
nfe-teste-hecc.xml
contrato-social-teste.pdf
recibo-folha-pagamento.pdf
gps-inss-comprovante.pdf
grf-fgts-comprovante.pdf
darf-irrf-comprovante.pdf
cnd-federal.pdf
crf-fgts.pdf
cndt.pdf

