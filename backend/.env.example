# =====================================================================
# .env.example — Variáveis de ambiente do Portal de Pagamentos FESF-SUS
# =====================================================================
# Copie para .env (que não vai ao git) e preencha conforme o ambiente.
# Em produção (Render), configure estes valores no painel de Environment.
# =====================================================================

# ---- Banco de dados ----
# Connection string do Postgres (Supabase). Se VAZIO, usa PGlite local (dev).
# Pegue em: https://supabase.com/dashboard/project/<seu-ref>/settings/database
# Use a "Connection string" mode = "Session" (porta 5432) para Express.
DATABASE_URL=

# ---- Segredos da aplicação ----
# JWT_SECRET: assinatura de tokens. Em produção, deixe o Render gerar.
JWT_SECRET=dev-secret-DEV-ONLY-change-in-prod

# APP_ENCRYPTION_KEY: encripta senhas SMTP e credenciais OneDrive (AES-256-GCM).
# 32+ caracteres aleatórios. Em produção, deixe o Render gerar.
APP_ENCRYPTION_KEY=dev-only-key-troque-em-producao-fesf-sus-2026

# ---- Ambiente ----
NODE_ENV=development
TZ=UTC
PORT=3000

# ---- CORS ----
# Lista de origens permitidas (separadas por vírgula). * = público (não use em prod)
CORS_ALLOWED_ORIGINS=*

# ---- Comportamento de jobs internos ----
# Intervalo do escalonamento de expectativas. 0 = desabilitado.
ESCALONAMENTO_INTERVALO_MS=300000
# Hora UTC do housekeeping diário (5 UTC = 02h Brasília)
HOUSEKEEPING_HOUR=5
# Desabilita o housekeeping completamente (1 = sim)
# HOUSEKEEPING_DISABLED=1

# ---- Seed ----
# SKIP_SEED=1 pula o seed no boot. Use em produção após primeiro deploy
# para evitar logs ruidosos (o seed é idempotente — não duplica dados).
# SKIP_SEED=1

# ---- Build metadata (informativo, aparece em /api/version) ----
APP_VERSION=V300
BUILD_COMMIT=
BUILD_TIME=

# ---- Logging ----
# LOG_QUIET=1 silencia logs informativos (mantém erros)
# LOG_QUIET=1

# ---- SMTP (opcional — alternativa: salvar via /app/admin-config.html) ----
# Se preferir configurar SMTP via env vars em vez do painel admin:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_DISABLED=0
